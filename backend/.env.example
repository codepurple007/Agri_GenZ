# Copy to `backend/.env` (do not commit). The API loads this file on startup (`src/loadEnv.js`).

# PostgreSQL connection string (optional — without it, auth uses in-memory storage)
# DATABASE_URL=postgres://user:pass@localhost:5432/agri_genz

PORT=3001

# Required in production — signs JWT sessions (defaults insecure for local dev)
# JWT_SECRET=change-me-to-a-long-random-string

# Demo staff passwords (override in production)
# DEMO_CLERK_PASSWORD=demo
# DEMO_ADMIN_PASSWORD=demo
# DEMO_INVESTOR_PASSWORD=demo
# DEMO_KEBELE_PASSWORD=demo
# DEMO_GAMEDA_PASSWORD=demo
# DEMO_VOICE_PASSWORD=demo
# DEMO_SUPERADMIN_PASSWORD=demo

# Demo Voice Recorder staff provisioned in memory on API start (default login nati / nati).
# STAFF_DEMO_VOICE_USERNAME=nati
# STAFF_DEMO_VOICE_PASSWORD=nati
# STAFF_DEMO_VOICE_FULL_NAME=Nati
# Estimated ETB per SMS segment (broadcast cost estimate)
# AGRI_SMS_COST_ETB=1

# Gemini — draft season / fertilizer / weather on advisory page (aggregator over farmer signup context)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
